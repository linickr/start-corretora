# ─────────────────────────────────────────────
# Google Analytics 4 — Data API
# ─────────────────────────────────────────────

# ID numérico da propriedade GA4 (só os números)
# Onde achar: analytics.google.com → Admin → Property Settings → Property ID
GA4_PROPERTY_ID=505846361

# Chave JSON da Service Account (conteúdo do arquivo .json baixado do Google Cloud)
# Cole o conteúdo completo do JSON em uma única linha
#
# Como criar:
#   1. Google Cloud Console → IAM & Admin → Service Accounts → Create
#   2. Ativar a API "Google Analytics Data API" no projeto
#   3. Baixar a chave JSON da service account
#   4. Copiar o conteúdo do JSON como string (sem quebras reais de linha)
#
# No GA4: Admin → Property Access Management → Add user → email da SA → Viewer
GOOGLE_SA_KEY={"type":"service_account","project_id":"seu-projeto",...}

# ─────────────────────────────────────────────
# NUNCA commite o arquivo .env.local com os valores reais!
# .env.local já está protegido no .gitignore
# ─────────────────────────────────────────────
